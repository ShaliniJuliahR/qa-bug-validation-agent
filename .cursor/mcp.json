{
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest"
            ]
        },
        "mcp-atlassian": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "--env-file",
                ".env",
                "ghcr.io/sooperset/mcp-atlassian:latest"
            ]
        },
        "zephyr-server": {
            "command": "npx",
            "args": [
                "dotenv-cli",
                "-e",
                ".env",
                "--",
                "npx",
                "zephyr-scale-mcp-server@latest"
            ]
        },
        "postman_mcp_server": {
            "url": "https://mcp.postman.com/minimal",
            "headers": {
                "Authorization": "Bearer <POSTMAN_API_KEY>"
            }
        }
    }
}